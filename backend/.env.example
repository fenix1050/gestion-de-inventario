# =============================================================
# backend/.env.example
# Copiá este archivo como .env y completá los valores reales
# NUNCA commitear el .env con valores reales
# =============================================================

NODE_ENV=development
PORT=3000

# Supabase — obtenés estos valores en:
# Settings → API del proyecto en supabase.com
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret — debe ser el mismo que usa Supabase internamente
# Lo encontrás en: Settings → API → JWT Settings → JWT Secret
JWT_SECRET=tu-jwt-secret-de-supabase

# Orígenes permitidos para CORS (separados por coma, sin espacios)
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
